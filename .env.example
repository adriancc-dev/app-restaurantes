# Supabase — obtén estos valores en https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Stripe — https://dashboard.stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...   # ID del precio de 100€/mes que crees en Stripe

# URLs de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PLAYSTORE_URL=https://play.google.com/store/apps/details?id=com.apprestaurantes
NEXT_PUBLIC_APPSTORE_URL=https://apps.apple.com/app/app-restaurantes/id000000000

# Email transaccional (Resend — https://resend.com)
RESEND_API_KEY=re_...
